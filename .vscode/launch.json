{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET: ExampleWebSite",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-example",
            "program": "${workspaceFolder}/example/bin/Debug/net10.0/ExampleWebSite.dll",
            "args": [],
            "cwd": "${workspaceFolder}/example",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            }
        },
        {
            "name": "C#: ExampleWebSite (Dev Kit)",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/example/ExampleWebSite.csproj"
        }
    ]
}
